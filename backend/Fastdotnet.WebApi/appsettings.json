{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "Storage": {
        "LocalStoragePath": "wwwroot/uploads",
        "BaseUrl": "/uploads",
        "DefaultBucket": "default"
    },
    "AllowedHosts": "*",
    "SqlSugar": {
        "EnableSqlExecutionLogging": true,
        "Connections": [
            {
                "ConfigId": "main",
                "ConnectionString": "DataSource=fd.db",
                "DbType": "Sqlite",
                "IsAutoCloseConnection": true
            },
            {
                "ConfigId": "log",
                "ConnectionString": "DataSource=log.db",
                "DbType": "Sqlite",
                "IsAutoCloseConnection": true
            }
        ]
        //"Connections": [
        //    {
        //        "ConfigId": "main",
        //        "ConnectionString": "Server=localhost;Database=fastdotnet;Uid=fastdotnet;Pwd=fastdotnet;SslMode=None;AllowLoadLocalInfile=true;AllowUserVariables=true;",
        //        "DbType": "MySql",
        //        "IsAutoCloseConnection": true
        //    },
        //    {
        //        "ConfigId": "log",
        //        "ConnectionString": "Server=localhost;Database=fastdotnet;Uid=fastdotnet;Pwd=fastdotnet;SslMode=None;AllowLoadLocalInfile=true;AllowUserVariables=true;",
        //        "DbType": "MySql",
        //        "IsAutoCloseConnection": true
        //    }
        //],
    },
    "JwtSettings": {
        "SecretKey": "a-very-string-and-secure-secret-key-that-is-at-least-32-bytes-string",
        "Issuer": "Fastdotnet",
        "Audience": "Fastdotnet.Api",
        "ExpirationInMinutes": 60
    },
    "CacheSettings": {
        "CacheType": "MemoryCache",
        "RedisConnectionString": "",
        "RedisInstanceName": "Fastdotnet:",
        "LocalCacheExpirationMinutes": 5,
        "DistributedCacheExpirationMinutes": 30
    },
    // LAZY.CAPTCHA 配置
    "CaptchaOptions": {
        "CaptchaType": 2, // 验证码类型: 1-中文, 2-数字, 3-数字+字母, 4-中文, 5-数字+字母+中文
        "CodeLength": 4, // 验证码长度
        "ExpirySeconds": 60, // 验证码过期时间(秒)
        "IgnoreCase": true, // 验证时是否忽略大小写
        "StorageKeyPrefix": "", // 存储键前缀
        // 频率限制配置
        "RateLimit": {
            "Enabled": false, // 是否启用频率限制
            "WindowSeconds": 60, // 时间窗口(秒)
            "MaxRequests": 5 // 最大请求数
        },
        // 图片选项
        "ImageOption": {
            "Animation": false, // 是否生成GIF动画
            "FontSize": 32, // 字体大小
            "Width": 100, // 图片宽度
            "Height": 40, // 图片高度
            "BubbleMinRadius": 5, // 气泡最小半径
            "BubbleMaxRadius": 8, // 气泡最大半径
            "BubbleCount": 3, // 气泡数量
            "BubbleThickness": 1.0, // 气泡线条粗细
            "InterferenceLineCount": 3, // 干扰线数量
            "FontFamily": "kaiti", // 字体族
            "FrameDelay": 15, // GIF动画帧延迟(毫秒)
            "BackgroundColor": "#ffffff", // 背景颜色
            "ForegroundColors": "", // 前景色(多个颜色用逗号分隔)
            "Quality": 100, // 图片质量(0-100)
            "TextBold": false // 文字是否加粗
        }
    },
    "RequestParamEncryption": {
        "PublicKey": "",
        "PrivateKey": "",
        "Algorithm": "RSA" //给人看的这里配置的密钥是什么类型，程序默认是RSA，不会读取这个
    }
}
