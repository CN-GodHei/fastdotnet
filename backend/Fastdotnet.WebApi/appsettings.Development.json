    "JwtSettings": {
        "SecretKey": "a-very-string-and-secure-secret-key-that-is-at-least-32-bytes-string",
        "Issuer": "Fastdotnet",
        "Audience": "Fastdotnet.Api",
        "ExpirationInMinutes": 60
    },
    // OIDC/OAuth2 Identity Provider 配置（OpenIddict）
    "OidcSettings": {
        "Enabled": true, // 设置为 true 启用 OIDC Identity Provider 功能
        "IssuerUri": "http://localhost:18889", // OIDC 颁发者地址
        "SigningKey": "oidc-signing-key-change-in-production-must-be-at-least-256-bits", // JWT 签名密钥
        "EncryptionKey": "oidc-encryption-key-change-in-production-must-be-at-least-256-bits", // JWT 加密密钥（可选）
        "AccessTokenLifetime": 60, // Access Token 有效期（分钟）
        "RefreshTokenLifetime": 30, // Refresh Token 有效期（天）
        "IdTokenLifetime": 60, // ID Token 有效期（分钟）
        "AllowRefreshTokens": true, // 是否允许刷新令牌
        "RequirePkce": true, // 是否要求 PKCE（生产环境建议启用）
        "RequireHttpsMetadata": false // 开发环境设为 false，生产环境必须设为 true
    },
    "CacheSettings": {
        "CacheType": "MemoryCache",
        "RedisConnectionString": "",
        "RedisInstanceName": "Fastdotnet:",
        "LocalCacheExpirationMinutes": 5,
        "DistributedCacheExpirationMinutes": 30
    },
    // LAZY.CAPTCHA 配置
    "CaptchaOptions": {
        "CaptchaType": 2, // 验证码类型: 1-中文, 2-数字, 3-数字+字母, 4-中文, 5-数字+字母+中文
        "CodeLength": 4, // 验证码长度
        "ExpirySeconds": 60, // 验证码过期时间(秒)
        "IgnoreCase": true, // 验证时是否忽略大小写
        "StorageKeyPrefix": "", // 存储键前缀
        // 频率限制配置
        "RateLimit": {
            "Enabled": false, // 是否启用频率限制
            "WindowSeconds": 60, // 时间窗口(秒)
            "MaxRequests": 5 // 最大请求数
        },
        // 图片选项
        "ImageOption": {
            "Animation": false, // 是否生成GIF动画
            "FontSize": 32, // 字体大小
            "Width": 100, // 图片宽度
            "Height": 40, // 图片高度
            "BubbleMinRadius": 5, // 气泡最小半径
            "BubbleMaxRadius": 8, // 气泡最大半径
            "BubbleCount": 3, // 气泡数量
            "BubbleThickness": 1.0, // 气泡线条粗细
            "InterferenceLineCount": 3, // 干扰线数量
            "FontFamily": "kaiti", // 字体族
            "FrameDelay": 15, // GIF动画帧延迟(毫秒)
            "BackgroundColor": "#ffffff", // 背景颜色
            "ForegroundColors": "", // 前景色(多个颜色用逗号分隔)
            "Quality": 100, // 图片质量(0-100)
            "TextBold": false // 文字是否加粗
        }
    },
    "RequestParamEncryption": {
        "PublicKey": "",
        "PrivateKey": "",
        "Algorithm": "RSA" //给人看的这里配置的密钥是什么类型，程序默认是RSA，不会读取这个
    },
    "PluginSettings": {
        "LoadDependenciesFromMemory": true,
        "EnableDeveloperMode": false
    },
    "Kestrel": {
        "Endpoints": {
            "Http": {
                "Url": "http://*:18889"
            }
        }
    }
}
