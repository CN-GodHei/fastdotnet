{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
    "SqlSugar": {
        "EnableSqlExecutionLogging": true,
        "Connections": [
            {
                "ConfigId": "main",
                "ConnectionString": "DataSource=fd.db",
                "DbType": "Sqlite",
                "IsAutoCloseConnection": true
            },
            {
                "ConfigId": "log",
                "ConnectionString": "DataSource=log.db",
                "DbType": "Sqlite",
                "IsAutoCloseConnection": true
            }
        ],
