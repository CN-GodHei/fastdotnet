# Docker Compose 环境变量文件
# 使用说明：
# 1. 复制此文件为 .env 或 .env.local
# 2. 修改下面的配置
# 3. 运行 docker-compose up -d

# ===========================================
# MySQL 配置（Docker 容器模式）
# ===========================================
MYSQL_IMAGE=mysql:8.0
MYSQL_ROOT_PASSWORD=fastdotnet_root
MYSQL_DATABASE=fastdotnet
MYSQL_USER=fastdotnet
MYSQL_PASSWORD=fastdotnet
MYSQL_PORT=3306

# 是否启用 MySQL 容器 (true/false)
USE_MYSQL_CONTAINER=true

# ===========================================
# 外部 MySQL 服务器配置（当不使用容器时）
# ===========================================
EXTERNAL_MYSQL_SERVER=localhost
EXTERNAL_MYSQL_PORT=3306
EXTERNAL_MYSQL_DATABASE=fastdotnet
EXTERNAL_MYSQL_USER=fastdotnet
EXTERNAL_MYSQL_PASSWORD=fastdotnet

# ===========================================
# Fastdotnet API 配置
# ===========================================
API_PORT=18889
ASPNETCORE_ENVIRONMENT=Production
