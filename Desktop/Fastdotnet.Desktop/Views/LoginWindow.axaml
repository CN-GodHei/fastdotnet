<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="Fastdotnet.Desktop.Views.LoginWindow"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="300"
        Title="Login" Width="400" Height="300" 
        WindowStartupLocation="CenterScreen">
  
  <Panel>
    <StackPanel Margin="20" Spacing="10">
      <TextBlock Text="Login" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,20"/>
      
      <TextBox Name="UsernameTextBox" Watermark="Username" />
      <TextBox Name="PasswordTextBox" Watermark="Password" />
      
      <Button Name="LoginButton" Content="Login" Margin="0,20,0,0" />
      
      <TextBlock Name="ErrorMessageTextBlock" Text="" Foreground="Red" TextWrapping="Wrap" />
    </StackPanel>
  </Panel>
</Window>