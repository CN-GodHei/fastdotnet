{
  "openApiPath": "http://localhost:18889/swagger/main/swagger.json",
  "namespace": "Fastdotnet.Desktop.Api",
  "contractsNamespace": "Fastdotnet.Desktop.Api.Models",
  "generateContracts": true,
  "generateClients": true,
  "generateXmlDocCodeComments": true,
  "addAutoGeneratedHeader": true,
  "generateOperationHeaders": true,
  "typeAccessibility": "Public",
  "useCancellationTokens": true,
  "generateInterfaces": true,
  "useNewtonsoftJson": true,
  "generateMultipleFiles": false,
  "outputFolder": "..\\Fastdotnet.Desktop\\Api",
  "contractsOutputFolder": "..\\Fastdotnet.Desktop\\Api\\Models",
  "naming": {
    "useOpenApiTitle": false,
    "interfaceName": "FastdotnetApi"
  },
  "returnIApiResponse": true,
  "additionalNamespaces": [
    "Newtonsoft.Json",
    "Newtonsoft.Json.Serialization",
    "System.Collections.Generic",
    "System.Threading.Tasks",
    "Fastdotnet.Desktop.Api.Models"
  ]
}